        "\"\"\"\n",
        "\n",
        "# === Step 2: Colang Rules ===\n",
        "# Added 3 more rules: role confusion, encoding obfuscation, and language override\n",
        "rails_co = \"\"\"\n",
        "# === User patterns ===\n",
        "\n",
        "define user ask about banking\n",
